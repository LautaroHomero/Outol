generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum CourtType {
  FIVE
  SEVEN
  ELEVEN
}

enum SurfaceType {
  SYNTHETIC
  NATURAL
  CEMENT
}

enum CourtStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum BadgeTone {
  BLUE
  RED
  GRAY
}

enum AmenityTone {
  GREEN
  BLUE
  RED
  NEUTRAL
}

model User {
  id           String        @id @default(cuid())
  auth0Id      String?       @unique
  name         String
  email        String?       @unique
  role         UserRole      @default(CUSTOMER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  favorites    Favorite[]
  reservations Reservation[]
  reviews      Review[]
}

model Venue {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  city         String
  neighborhood String
  address      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  courts       Court[]
  promotions   Promotion[]
}

model Court {
  id                     String         @id @default(cuid())
  slug                   String         @unique
  venueId                String
  name                   String
  courtType              CourtType
  surface                SurfaceType
  isCovered              Boolean        @default(false)
  hasLighting            Boolean        @default(false)
  hasParking             Boolean        @default(false)
  hasLockerRoom          Boolean        @default(false)
  hourlyPrice            Int
  oldHourlyPrice         Int?
  distanceKm             Float
  ratingAverage          Float          @default(0)
  reviewsCount           Int            @default(0)
  status                 CourtStatus    @default(AVAILABLE)
  featured               Boolean        @default(false)
  noSlotsToday           Boolean        @default(false)
  badgeLabel             String?
  badgeTone              BadgeTone?
  paletteWrapClass       String
  paletteFieldClass      String
  paletteLineBorderClass String
  paletteLineBgClass     String
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  venue                  Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  amenities              CourtAmenity[]
  favorites              Favorite[]
  reservations           Reservation[]
  reviews                Review[]
  slots                  CourtSlot[]
}

model Amenity {
  id        String         @id @default(cuid())
  slug      String         @unique
  label     String
  tone      AmenityTone    @default(NEUTRAL)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  courts    CourtAmenity[]
}

model CourtAmenity {
  courtId   String
  amenityId String
  court     Court   @relation(fields: [courtId], references: [id], onDelete: Cascade)
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([courtId, amenityId])
}

model CourtSlot {
  id        String   @id @default(cuid())
  courtId   String
  label     String
  position  Int
  createdAt DateTime @default(now())
  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
}

model Favorite {
  userId    String
  courtId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@id([userId, courtId])
}

model Reservation {
  id        String            @id @default(cuid())
  userId    String
  courtId   String
  startsAt  DateTime
  endsAt    DateTime
  status    ReservationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  court     Court             @relation(fields: [courtId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  userId    String?
  courtId   String
  rating    Float
  comment   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
}

model Promotion {
  id        String   @id @default(cuid())
  venueId   String?
  title     String
  subtitle  String
  ctaLabel  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  venue     Venue?   @relation(fields: [venueId], references: [id], onDelete: SetNull)
}
